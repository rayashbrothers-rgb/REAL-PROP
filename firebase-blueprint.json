{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A real estate project listing",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The name of the project" },
        "image": { "type": "string", "description": "URL to the project image" },
        "location": { "type": "string", "description": "Location of the project" },
        "type": { "type": "string", "description": "Type of property (Shop/Office/Flat/Investment)" },
        "description": { "type": "string", "description": "Detailed description of the project" },
        "category": { "type": "string", "description": "Residential/Commercial/Investment/Plots", "enum": ["Residential", "Commercial", "Investment", "Plots"] },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the project was added" }
      },
      "required": ["title", "image", "location", "type", "description", "category"]
    },
    "Lead": {
      "title": "Lead",
      "description": "A potential customer lead",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Customer name" },
        "phone": { "type": "string", "description": "Customer phone number" },
        "propertyInterest": { "type": "string", "description": "Property type they are interested in" },
        "budget": { "type": "string", "description": "Budget range" },
        "location": { "type": "string", "description": "Preferred location" },
        "message": { "type": "string", "description": "Additional message" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the lead was submitted" }
      },
      "required": ["name", "phone"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of real estate projects"
    },
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Collection of customer leads"
    }
  }
}
