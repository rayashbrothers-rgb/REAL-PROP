rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: projects
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - image: string (required)
    //   - location: string (required)
    //   - type: string (required)
    //   - description: string (required)
    //   - category: string (required) - enum: ["Residential", "Commercial", "Investment", "Plots"]
    //   - createdAt: timestamp (required)
    //
    // Collection: leads
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - phone: string (required)
    //   - propertyInterest: string (optional)
    //   - budget: string (optional)
    //   - location: string (optional)
    //   - message: string (optional)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "rayashbrothers@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidProject(data) {
      return data.keys().hasAll(['title', 'image', 'location', 'type', 'description', 'category', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.image is string && data.image.size() > 0 &&
             data.location is string && data.location.size() > 0 &&
             data.type is string && data.type.size() > 0 &&
             data.description is string && data.description.size() > 0 &&
             data.category in ["Residential", "Commercial", "Investment", "Plots"] &&
             data.createdAt is timestamp;
    }

    function isValidLead(data) {
      return data.keys().hasAll(['name', 'phone', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.phone is string && data.phone.size() > 0 && data.phone.size() < 20 &&
             data.createdAt is timestamp &&
             (!('propertyInterest' in data) || (data.propertyInterest is string && data.propertyInterest.size() < 100)) &&
             (!('budget' in data) || (data.budget is string && data.budget.size() < 100)) &&
             (!('location' in data) || (data.location is string && data.location.size() < 100)) &&
             (!('message' in data) || (data.message is string && data.message.size() < 1000));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /projects/{projectId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidProject(request.resource.data);
    }

    match /leads/{leadId} {
      allow read: if isAdmin();
      allow create: if isValidLead(request.resource.data);
      allow update, delete: if isAdmin();
    }
  }
}
